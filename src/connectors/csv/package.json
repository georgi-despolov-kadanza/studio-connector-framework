{
  "name": "csv",
  "description": "Use any publicly accessible CSV (UTF-8) file as a data source.",
  "version": "1.0.4",
  "private": true,
  "author": {
    "name": "Spicy Labs",
    "email": "admin@spicy-labs.com",
    "url": "https://github.com/spicy-labs"
  },
  "config": {
    "connectorName": "CSV",
    "type": "data",
    "iconUrl": "https://studio-cdn.chiligrafx.com/shared/demo-connectors/csv-connector.svg",
    "options": {},
    "mappings": {},
    "authenticationConfig": {
      "oAuth2AuthorizationCode": {
        "authorizationServerMetadata": {
          "token_endpoint_auth_methods_supported": [
            "client_secret_post",
            "client_secret_basic"
          ]
        }
      }
    },
    "supportedAuth": [
      "staticKey",
      "oAuth2ClientCredentials",
      "oAuth2AuthorizationCode",
      "oAuth2ResourceOwnerPassword"
    ]
  },
  "license": "MIT",
  "main": "out/connector.js",
  "dependencies": {
    "@chili-publish/studio-connectors": "^1.39.0"
  },
  "scripts": {
    "build": "yarn connector-cli build",
    "test": "yarn connector-cli test -t tests.json"
  },
  "devDependencies": {
    "@chili-publish/connector-cli": "^1.9.0",
    "typescript": "^5.2.2"
  }
}
